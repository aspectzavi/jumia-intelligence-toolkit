# ==================================================
# Browser
# ==================================================

BROWSER=chromium

HEADLESS=false

SLOW_MO=200

TIMEOUT=30000

# ==================================================
# Website
# ==================================================

BASE_URL=https://www.jumia.co.ke

# ==================================================
# Locale
# ==================================================

LOCALE=en-KE

TIMEZONE=Africa/Nairobi

# ==================================================
# Viewport
# ==================================================

VIEWPORT_WIDTH=1920

VIEWPORT_HEIGHT=1080

# ==================================================
# User Agent
# Leave empty to use Playwright default
# ==================================================

USER_AGENT=

# ==================================================
# Logging
# ==================================================

LOG_LEVEL=INFO

LOG_FILE=logs/jit.log

LOG_ROTATION=10 MB

LOG_RETENTION=30 days

# ==================================================
# Storage
# ==================================================

STATE_PATH=data/playwright/storage_state.json

COOKIE_PATH=data/playwright/cookies.json

DOWNLOAD_PATH=data/playwright/downloads

TRACE_PATH=data/playwright/traces

# ==================================================
# Captures
# ==================================================

CAPTURE_PATH=data/captures

REQUEST_PATH=data/captures/requests

RESPONSE_PATH=data/captures/responses

SCREENSHOT_PATH=data/captures/screenshots

VIDEO_PATH=data/captures/videos
